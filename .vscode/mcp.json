{
	"servers": {
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest"
			]
		},
		"coherence-prototyper": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"tsx",
				"${workspaceFolder}/mcp-server/main.ts"
			]
		},
		"figma": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp",
			"headers": {
				"Authorization": "Bearer ${env:FIGMA_ACCESS_TOKEN}"
			}
		}
	}
}
